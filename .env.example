# ─── Bitrix24 ────────────────────────────────────
BITRIX24_WEBHOOK_URL=https://tootmx.bitrix24.kz/rest/98/nh06zqmcwxx3ylyn/
BITRIX24_DOMAIN=tootmx.bitrix24.kz
ADMIN_1_ID=1
