# ─── Supabase (supabase.com → Project Settings) ──
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   ← service_role key (Settings → API)

# Эти два — VITE_ префикс, для браузера
VITE_SUPABASE_URL=https://XXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...  ← anon/public key (Settings → API)

# ─── Kaspi Seller API ─────────────────────────────
